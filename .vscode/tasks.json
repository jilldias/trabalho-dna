{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile DNA Analyzer",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "${workspaceFolder}/main.c",
        "${workspaceFolder}/cadastro.c",
        "${workspaceFolder}/analise.c",
        "${workspaceFolder}/ordenacao.c",
        "${workspaceFolder}/arquivo.c",
        "${workspaceFolder}/comparacao.c",
        "-o",
        "${workspaceFolder}/output/main.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}